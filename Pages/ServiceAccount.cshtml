@page "/serviceaccount"
@using CurriculumPortal
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = Roles.Admin)]
@model ServiceAccountModel
@inject AppOptions AppOptions
@{
  ViewData["Title"] = $"Service Account - {AppOptions.SchoolName}";
}

@section Head {
  <link rel="stylesheet" href="/css/curriculum.css" />
}

<div class="content-page">
  <main class="active">
    <h2 class="course-title">Service account</h2>

    @if (Model.Status.HasError)
    {
      <p style="color: #b00020; font-weight: bold">@Model.Status.Message</p>
    }
    else
    {
      <p>@Model.Status.Message</p>
    }

    @if (Model.Status.RefreshTokenExpiresUtc is not null)
    {
      <p>Refresh token expiry: <b>@Model.Status.RefreshTokenExpiresUtc.Value.ToString("dddd d MMMM yyyy 'at' HH:mm 'UTC'")</b></p>
    }

    @if (!string.IsNullOrWhiteSpace(Model.Status.AuthorizationUrl))
    {
      <p><a href="@Model.Status.AuthorizationUrl">Sign in with Microsoft</a></p>
    }
    else if (!string.IsNullOrWhiteSpace(Model.Status.ReauthenticateUrl))
    {
      <p><a href="@Model.Status.ReauthenticateUrl">Reauthenticate now</a></p>
    }
  </main>
</div>
